---
import Layout from "../layouts/Base.astro";
import { loadProjects, getProject, displayCategory } from "../lib/projects.js";

export function getStaticPaths() {
  return loadProjects().map((p) => ({
    params: { slug: p.project_row.slug },
  }));
}

const { slug } = Astro.params;
const p = getProject(slug);
if (!p) return Astro.redirect("/");

const r = p.project_row;
const c = p.revision_content || {};
const brief = c.brief || {};
const assessment = c.assessment || {};
const sources = c.sources || [];
const disclaimer = c.disclaimer || {};

const SITE_URL = "https://beforethetoken.vercel.app";

// Favicon via Google service, unified with list view
const PROJECT_DOMAIN = {
  genlayer: "genlayer.com",
  pixiechess: "pixiechess.xyz",
  perpl: "perpl.xyz",
  arcus: "arcus.xyz",
};
function logoUrl(slug) {
  const domain = PROJECT_DOMAIN[slug] || `${slug}.com`;
  return `https://www.google.com/s2/favicons?domain=${domain}&sz=256`;
}

const PROJECT_SHORT_DESC = ((brief.whats_cooking || "")
  .split("\n\n")
  .map((s) => s.trim())
  .find((s) => s) || `${r.name}: ${displayCategory(r.category)} project.`)
  .slice(0, 150);
const PROJECT_IMAGE = logoUrl(slug);
const PROJECT_URL = `${SITE_URL}/${slug}`;

// related / recent: other projects (exclude current)
const related = loadProjects()
  .filter((x) => x.project_row.slug !== slug)
  .slice(0, 6)
  .map((x) => ({ slug: x.project_row.slug, name: x.project_row.name, logo: logoUrl(x.project_row.slug) }));
---

<Layout title={`${r.name} - Before The Token`}>
  <head slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:url" content={PROJECT_URL} />
    <meta property="og:title" content={r.name} />
    <meta property="og:description" content={PROJECT_SHORT_DESC} />
    <meta property="og:image" content={PROJECT_IMAGE} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={r.name} />
    <meta name="twitter:description" content={PROJECT_SHORT_DESC} />
    <meta name="twitter:image" content={PROJECT_IMAGE} />
  </head>
  <div class="dwrap">
    <!-- left rail: back + recent -->
    <aside class="drail">
      <button class="dback" onclick="if (history.length > 1) history.back(); else location.href='/';">&larr; Back</button>
      <div class="drail-h">Recent research</div>
      <nav class="drec">
        {related.map((x) => (
          <a class="drec-card" href={`/${x.slug}`}>
            <img class="drec-logo" src={x.logo} alt={x.name} width="28" height="28" loading="lazy" onerror={`this.outerHTML='<span class=&quot;drec-glyph&quot;>${x.name[0]}</span>'`} />
            <span class="drec-name">{x.name}</span>
          </a>
        ))}
      </nav>
    </aside>

    <!-- center: content -->
    <div class="dmain">
    <div class="dhead">
      <div class="dhead-left">
        <img class="dlogo" src={logoUrl(slug)} alt={r.name} width="56" height="56" loading="lazy" onerror={`this.outerHTML='<span class=&quot;dlogo-glyph&quot;>${r.name[0]}</span>'`} />
        <div class="dhead-main">
          <h1>{r.name}</h1>
          <div class="dpills">
            <span class="dpill">{displayCategory(r.category)}</span>
            {r.funding_summary ? <span class="dpill">{r.funding_summary}</span> : ""}
          </div>
        </div>
      </div>
      <div class="dlink">
        {r.website_url && (
          <a href={r.website_url} target="_blank" rel="noopener" title="Website" aria-label="Website">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
          </a>
        )}
        {r.x_url && (
          <a href={r.x_url} target="_blank" rel="noopener" title="X" aria-label="X">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.9 2H22l-7.5 8.6L23 22h-6.8l-5.3-6.9L4.8 22H1.7l8-9.2L1 2h7l4.8 6.3L18.9 2zm-2.4 18h1.9L7.6 4H5.6l10.9 16z"/></svg>
          </a>
        )}
      </div>
    </div>

      <section class="module">
        <h2><span class="mnum">01</span>What's Cooking</h2>
        {brief.whats_cooking.split("\n\n").map((para) => <p>{para}</p>)}
      </section>
      <section class="module">
        <h2><span class="mnum">02</span>How It Makes Money</h2>
        {brief.how_it_makes_money.split("\n\n").map((para) => <p>{para}</p>)}
      </section>
      <section class="module">
        <h2><span class="mnum">03</span>How It Grows</h2>
        {brief.how_it_grows.split("\n\n").map((para) => <p>{para}</p>)}
      </section>
      <section class="module">
        <h2><span class="mnum">04</span>Why It May Matter</h2>
        {brief.why_it_may_matter.split("\n\n").map((para) => <p>{para}</p>)}
      </section>

      {assessment.warnings?.length > 0 && (
        <section class="module">
          <h2>Warnings</h2>
          <ul>
            {assessment.warnings.map((w) => <li>{w}</li>)}
          </ul>
        </section>
      )}

      {assessment.watch_next?.length > 0 && (
        <section class="module">
          <h2>Watch Next</h2>
          <ul>
            {assessment.watch_next.map((w) => <li>{w}</li>)}
          </ul>
        </section>
      )}

      {sources.filter((s) => s.url && s.url.trim()).length > 0 && (
        <section class="module">
          <details class="src-details">
            <summary>Sources</summary>
            <ul class="sources">
              {sources.filter((s) => s.url && s.url.trim()).map((s) => (
                <li><a href={s.url} target="_blank" rel="noopener">{s.title}</a></li>
              ))}
            </ul>
          </details>
        </section>
      )}


      </div>  <!-- close .dmain -->
    <aside class="dright"></aside>
  </div>
</Layout>
