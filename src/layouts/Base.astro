---
const { title = "Before The Token" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;510;590&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #08090a;
        --panel: #0f1011;
        --surface: #191a1b;
        --text: #f7f8f8;
        --text-2: #d0d6e0;
        --muted: #8a8f98;
        --faint: #62666d;
        --accent: #5e6ad2;
        --accent-hover: #828fff;
        --border: rgba(255, 255, 255, 0.08);
        --border-subtle: rgba(255, 255, 255, 0.05);
        --radius: 8px;
      }
      * { box-sizing: border-box; }
      html { -webkit-font-smoothing: antialiased; }
      body {
        margin: 0;
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        font-feature-settings: 'cv01', 'ss03';
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
        font-weight: 400;
      }
      .wrap { max-width: 760px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
      :global(a) { color: var(--accent-hover); text-decoration: none; transition: color .15s; }
      :global(a:hover) { color: var(--accent-hover); text-decoration: underline; }
      header.site {
        border-bottom: 1px solid var(--border-subtle);
        margin-bottom: 2.5rem;
        padding-bottom: 1.25rem;
      }
      header.site .brand { font-weight: 590; font-size: 1.05rem; letter-spacing: -0.24px; }
      header.site .brand a { color: var(--text); text-decoration: none; }
      header.site .tag { color: var(--muted); font-size: 0.85rem; margin-top: 0.25rem; }
      h1 { font-weight: 510; font-size: 2rem; letter-spacing: -0.704px; line-height: 1.1; margin: 0 0 0.5rem; }
      h2 { font-weight: 590; font-size: 1.25rem; letter-spacing: -0.24px; margin: 0 0 0.5rem; }
      .lead { color: var(--muted); font-size: 0.95rem; }
      .disclaimer {
        margin-top: 3rem; padding-top: 1.25rem; border-top: 1px solid var(--border-subtle);
        color: var(--faint); font-size: 0.8rem;
      }
      .badge {
        display: inline-block; padding: 0.15rem 0.6rem; border-radius: 9999px;
        font-size: 0.72rem; font-weight: 510; border: 1px solid rgba(255,255,255,0.12);
        color: var(--text-2); margin-right: 0.4rem; background: rgba(255,255,255,0.02);
      }
      .module { margin-top: 2rem; }
      .module h2 { font-size: 1.05rem; }
      .module p { color: var(--text-2); font-size: 0.97rem; }
      .card {
        display: block; color: var(--text-2); text-decoration: none;
        border: 1px solid var(--border); border-radius: var(--radius);
        padding: 1.1rem 1.2rem; margin-bottom: 0.9rem;
        background: rgba(255,255,255,0.02);
        transition: background .15s, border-color .15s;
      }
      .card:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.12); text-decoration: none; }
      .card .name { font-weight: 590; font-size: 1.05rem; letter-spacing: -0.24px; color: var(--text); }
      .card .teaser { color: var(--muted); font-size: 0.88rem; margin-top: 0.4rem; line-height: 1.5; }
      .card .badges { margin-top: 0.6rem; }
      .filters { margin: 1.25rem 0 2rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
      input, select {
        background: rgba(255,255,255,0.02); color: var(--text);
        border: 1px solid var(--border); border-radius: 6px;
        padding: 0.55rem 0.7rem; font-family: inherit; font-size: 0.9rem;
      }
      input::placeholder { color: var(--faint); }
      input:focus, select:focus { outline: none; border-color: var(--accent); }
      ul { color: var(--text-2); font-size: 0.92rem; }
      .meta { color: var(--muted); font-size: 0.85rem; margin-top: 0.4rem; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <div class="brand"><a href="/">Before The Token</a></div>
        <div class="tag">Researching crypto projects before the token.</div>
      </header>
      <main>
        <slot />
      </main>
      <div class="disclaimer">
        Listing is information, not endorsement. Not investment advice.
      </div>
    </div>
  </body>
</html>
