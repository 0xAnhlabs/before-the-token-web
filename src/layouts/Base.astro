---
const { title = "Before The Token" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;510;590&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #08090a;
        --panel: #0f1011;
        --surface: #191a1b;
        --surface-2: #1f2022;
        --text: #f7f8f8;
        --text-2: #d0d6e0;
        --muted: #8a8f98;
        --faint: #62666d;
        --accent: #5e6ad2;
        --accent-hover: #828fff;
        --green: #10b981;
        --amber: #f5a623;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.14);
        --radius: 10px;
        --maxw: 880px;
      }
      * { box-sizing: border-box; }
      html { -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        font-feature-settings: 'cv01', 'ss03';
        background: var(--bg);
        color: var(--text);
        line-height: 1.55;
        font-weight: 400;
      }
      :global(a) { color: var(--accent-hover); text-decoration: none; transition: color .15s; }
      :global(a:hover) { color: var(--accent-hover); text-decoration: underline; }

      header.nav {
        position: sticky; top: 0; z-index: 10;
        background: rgba(8, 9, 10, 0.72);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      header.nav .inner {
        max-width: var(--maxw); margin: 0 auto;
        padding: 0.85rem 1.25rem;
        display: flex; align-items: center; justify-content: space-between;
      }
      header.nav .brand { font-weight: 590; font-size: 0.98rem; letter-spacing: -0.24px; color: var(--text); }
      header.nav .brand a { color: var(--text); }
      header.nav .tag { color: var(--muted); font-size: 0.8rem; }

      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 2.75rem 1.25rem 4rem; }
      h1 { font-weight: 510; font-size: 2.1rem; letter-spacing: -0.7px; line-height: 1.1; margin: 0 0 0.4rem; }
      h2 { font-weight: 590; font-size: 1.15rem; letter-spacing: -0.24px; margin: 0 0 0.5rem; }
      .lead { color: var(--muted); font-size: 0.95rem; }

      .disclaimer {
        margin-top: 3.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border);
        color: var(--faint); font-size: 0.8rem;
      }

      .badge {
        display: inline-block; padding: 0.18rem 0.6rem; border-radius: 9999px;
        font-size: 0.72rem; font-weight: 510; margin-right: 0.4rem; margin-bottom: 0.3rem;
        border: 1px solid var(--border-strong);
        color: var(--text-2); background: rgba(255,255,255,0.03);
      }
      .badge.green { color: var(--green); border-color: rgba(16,185,129,0.3); background: rgba(16,185,129,0.08); }
      .badge.amber { color: var(--amber); border-color: rgba(245,166,35,0.3); background: rgba(245,166,35,0.08); }
      .badge.violet { color: var(--accent-hover); border-color: rgba(130,143,255,0.3); background: rgba(94,106,210,0.12); }

      .module { margin-top: 2.25rem; }
      .module h2 { font-size: 1.05rem; color: var(--text); }
      .module p { color: var(--text-2); font-size: 0.98rem; }

      /* card list */
      .card {
        display: block; color: var(--text-2); text-decoration: none;
        background: var(--surface);
        border: 1px solid var(--border); border-radius: var(--radius);
        padding: 1.25rem 1.35rem; margin-bottom: 1rem;
        transition: background .15s, border-color .15s, transform .15s;
      }
      .card:hover {
        background: var(--surface-2); border-color: var(--border-strong);
        text-decoration: none; transform: translateY(-2px);
      }
      .card .name { font-weight: 590; font-size: 1.1rem; letter-spacing: -0.24px; color: var(--text); }
      .card .teaser { color: var(--muted); font-size: 0.9rem; margin-top: 0.5rem; line-height: 1.55; }
      .card .badges { margin-top: 0.75rem; }

      .filters { margin: 1.5rem 0 2rem; display: flex; flex-wrap: wrap; gap: 0.6rem; }
      input, select {
        background: var(--surface); color: var(--text);
        border: 1px solid var(--border-strong); border-radius: 8px;
        padding: 0.6rem 0.8rem; font-family: inherit; font-size: 0.9rem;
      }
      input::placeholder { color: var(--faint); }
      input:focus, select:focus { outline: none; border-color: var(--accent); }
      select { cursor: pointer; }

      ul.sources { color: var(--text-2); font-size: 0.9rem; padding-left: 1.1rem; }
      ul.sources li { margin-bottom: 0.35rem; }
      .meta { color: var(--muted); font-size: 0.85rem; margin-top: 0.4rem; }
      .empty { color: var(--faint); font-size: 0.85rem; font-style: italic; }
    </style>
  </head>
  <body>
    <header class="nav">
      <div class="inner">
        <div class="brand"><a href="/">Before The Token</a></div>
        <div class="tag">Research, before the token.</div>
      </div>
    </header>
    <div class="wrap">
      <main>
        <slot />
      </main>
      <div class="disclaimer">
        Listing is information, not endorsement. Not investment advice.
      </div>
    </div>
  </body>
</html>
